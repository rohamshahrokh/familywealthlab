# ──────────────────────────────────────────────────────────────────────
# Family Wealth Lab — Commercial site
# Copy to .env.local for local development. In Netlify, set these in
# Site settings → Environment variables.
# ──────────────────────────────────────────────────────────────────────

# Supabase project — create a NEW project (e.g. "fwl-commercial-prod")
# separate from any other FWL Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Site URL — used for OAuth redirects and email links.
# Production: https://family-wealth-lab.netlify.app  (or custom domain)
# Local dev:   http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: require MFA for sensitive routes (e.g. /settings/security).
# Set to "true" to enforce step-up authentication after initial login.
NEXT_PUBLIC_MFA_REQUIRED=false
