# ──────────────────────────────────────────────────────────────────────
# Family Wealth Lab — Commercial site
# Copy to .env.local for local development. In Netlify, set these in
# Site settings → Environment variables.
# ──────────────────────────────────────────────────────────────────────

# Supabase project — create a NEW project (e.g. "fwl-commercial-prod")
# separate from any other FWL Supabase project. The commercial codebase
# has zero hardcoded Supabase URLs/keys — every fetch() reads from these
# env vars at runtime/build (NEXT_PUBLIC_* values are inlined by Next).
# Direct-fetch helpers in src/components/port/pages/* and
# src/lib/finance-port/* short-circuit when these are unset or set to the
# placeholder values below, so the app boots cleanly without a project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Site URL — used for OAuth redirects and email links.
# Production: https://family-wealth-lab.netlify.app  (or custom domain)
# Local dev:   http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: require MFA for sensitive routes (e.g. /settings/security).
# Set to "true" to enforce step-up authentication after initial login.
NEXT_PUBLIC_MFA_REQUIRED=false

# Founder/internal mode — when "1" (default), `getEntitlements()` returns
# the `founder` tier unconditionally and every gated feature is unlocked.
# Flip to "0" to enable real commercial gating via billing.subscriptions.
# Canonical tiers: free / starter / pro / family_office / founder.
NEXT_PUBLIC_FWL_FOUNDER_MODE=1
